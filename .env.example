# IMPORTANT
# Copy this file to `.env` and fill in only the providers you actually
# use. Do not commit your real `.env`; this `.env.example` is the safe
# template checked into version control.
#
# LM providers (`language_model:` in YAML) route through litellm — the
# variable names below match litellm's conventions exactly. Embedding
# models (`embedding_model:` for cosine_similarity rewards) reuse the
# same provider keys.

# --- LM / embedding providers -----------------------------------------------
# OpenAI (also covers DeepEval's default judge model and Doubleword)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# Groq
GROQ_API_KEY=

# Together AI (note the `_AI_` suffix — litellm convention)
TOGETHER_AI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Azure OpenAI — needs all three
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# Self-hosted: Ollama (defaults to http://localhost:11434)
OLLAMA_API_BASE=

# Self-hosted: vLLM (defaults to http://localhost:8000)
HOSTED_VLLM_API_BASE=

# HuggingFace Hub — needed for gated/private datasets and the
# `huggingface` dataset provider's `token:` kwarg.
HF_TOKEN=

# --- Dataset providers ------------------------------------------------------
# Langfuse (`type: langfuse`)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# LangSmith (`type: langsmith`)
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=

# Opik / Comet (`type: opik`)
OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_URL_OVERRIDE=

# Arize Phoenix (`type: phoenix`) — pick `PHOENIX_COLLECTOR_ENDPOINT`
# OR the `PHOENIX_HOST` + `PHOENIX_PORT` pair.
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=
# PHOENIX_HOST=
# PHOENIX_PORT=

# Braintrust (`type: braintrust`)
BRAINTRUST_API_KEY=
BRAINTRUST_APP_URL=
BRAINTRUST_ORG_NAME=

# --- MCP servers ------------------------------------------------------------
# Per-server auth (e.g. bearer tokens for streamable_http / sse transports)
# is set on the connection's `headers:` map in the top-level
# `mcp_servers:` registry in YAML, not via global env vars. Any env var
# the YAML interpolates (e.g. `${MY_MCP_TOKEN}`) belongs here.
